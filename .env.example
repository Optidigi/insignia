# =============================================================================
# Insignia Shopify App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env — it is listed in .gitignore.
# This file (.env.example) IS committed and must never contain real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Shopify App Credentials
# Auto-populated by `shopify app dev` for the development environment.
# For production, copy from the Partner Dashboard → App setup → Client credentials.
# -----------------------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# NOTE: Scopes are defined in shopify.app.*.toml, NOT here. The SCOPES env var
# is only used as a fallback by shopify.server.ts if the toml-derived value is
# absent. Leave this empty or matching the toml scopes exactly.
SCOPES=

# Tunnel URL in dev (set automatically by Shopify CLI).
# Production URL in prod (e.g. https://your-app.example.com).
SHOPIFY_APP_URL=


# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://insignia:change_me@localhost:5432/insignia

POSTGRES_USER=insignia
POSTGRES_PASSWORD=change_me
POSTGRES_DB=insignia


# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# Obtain from Cloudflare Dashboard → R2 → Manage R2 API tokens.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=


# -----------------------------------------------------------------------------
# Cron Authentication
# Required in production — all /api/admin/cron/* endpoints verify this secret.
# Generate with: openssl rand -hex 32
# Call cron endpoints with: Authorization: Bearer <CRON_SECRET>
# See docs/ops/cron-setup.md for the full cron configuration.
# -----------------------------------------------------------------------------
CRON_SECRET=


# -----------------------------------------------------------------------------
# Error Tracking (Sentry)
# Obtain from sentry.io → Project → Settings → Client Keys (DSN).
# Leave empty to disable Sentry (the app starts normally without it).
# -----------------------------------------------------------------------------
SENTRY_DSN=


# -----------------------------------------------------------------------------
# Merchant Email Notifications (optional)
# Obtain from resend.com → API Keys.
# Leave empty to disable email notifications (orders still process normally).
# See app/lib/services/merchant-notifications.server.ts for usage.
# -----------------------------------------------------------------------------
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# Optional / Miscellaneous
# -----------------------------------------------------------------------------

# Override the shop domain used during development (uncomment if needed).
# SHOP_CUSTOM_DOMAIN=
