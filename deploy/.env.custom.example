# ── Insignia Custom/Private App — Production Environment ─────────────────────
# Copy to /srv/saas/infra/stacks/insignia-custom/.env and fill in all values.
# Never commit the real .env to git.
# Set permissions: chmod 600 .env
#
# This is for the SECOND app instance (custom/private Shopify app).
# These credentials are entirely separate from the public Insignia app.

# ── Shopify ───────────────────────────────────────────────────────────────────
# Get these from Shopify Partner Dashboard → Apps → <your CUSTOM app> → API credentials
# The client_id here is DIFFERENT from the public app.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Must match [access_scopes] in shopify.app.insignia-custom.toml exactly.
SCOPES=write_products,read_products,read_orders,write_orders,write_app_proxy,write_publications,write_inventory,read_themes
# Replace with the actual domain for the custom app instance.
SHOPIFY_APP_URL=https://insignia-custom.optidigi.nl

# ── Database (app connection string) ─────────────────────────────────────────
# "db" is the Docker service name — reachable by the app on the internal network.
# This MUST point to this stack's own db container — NOT the public app's db.
DATABASE_URL=postgresql://insignia_custom:CHANGE_ME@db:5432/insignia_custom

# ── Database (PostgreSQL container init) ─────────────────────────────────────
# POSTGRES_PASSWORD must match the password in DATABASE_URL above.
# Use different values from the public app to avoid any accidental cross-connection.
POSTGRES_USER=insignia_custom
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=insignia_custom

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
# Recommended: use a SEPARATE R2 bucket for this instance.
# This gives independent cost tracking, CORS policy, and backup schedule.
# The R2 API token can be from the same Cloudflare account — just a different bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=insignia-custom-assets
# If using a separate bucket, set a new R2 public domain or r2.dev URL.
R2_PUBLIC_URL=https://assets-custom.optidigi.nl

# ── Cron Authentication ───────────────────────────────────────────────────────
# Generate a SEPARATE secret — do not reuse the public app's CRON_SECRET.
# Generate with: openssl rand -hex 32
# Use in cron: curl -H "Authorization: Bearer $CRON_SECRET" ...
CRON_SECRET=

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Can share the same Sentry project or use a separate one.
# Leave empty to disable.
SENTRY_DSN=

# ── Merchant Email Notifications (Resend) ─────────────────────────────────────
# Can share the same Resend API key or use a separate sender domain.
# Leave empty to disable.
RESEND_API_KEY=

# ── Deployment ────────────────────────────────────────────────────────────────
APP_VERSION=latest

# ── Optional ──────────────────────────────────────────────────────────────────
# SHOP_CUSTOM_DOMAIN=
