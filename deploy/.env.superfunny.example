# Insignia SuperFunny production environment.
# Copy to /srv/saas/infra/stacks/insignia-superfunny/.env and fill in real secrets.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_products,read_products,read_orders,write_orders,write_app_proxy,write_publications,write_inventory,read_themes
SHOPIFY_APP_URL=https://insignia-superfunny.optidigi.nl

DATABASE_URL=postgresql://insignia_superfunny:CHANGE_ME@db:5432/insignia_superfunny
POSTGRES_USER=insignia_superfunny
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=insignia_superfunny

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=insignia-superfunny-assets
R2_PUBLIC_URL=https://assets-superfunny.optidigi.nl

CRON_SECRET=
DESIGN_FEES_ENABLED=true
SENTRY_DSN=
RESEND_API_KEY=
APP_VERSION=latest

# SHOP_CUSTOM_DOMAIN=
