# Insignia Stitchs production environment.
# Copy to /srv/saas/infra/stacks/insignia-stitchs/.env and fill in real secrets.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_products,read_products,read_orders,write_orders,write_app_proxy,write_publications,write_inventory,read_themes
SHOPIFY_APP_URL=https://insignia-stitchs.optidigi.nl

# Existing Stitchs data was created under the former `insignia-custom` stack.
# Keep these logical DB names unless you also perform a deliberate Postgres
# database/user rename inside the cluster.
DATABASE_URL=postgresql://insignia_custom:CHANGE_ME@db:5432/insignia_custom
POSTGRES_USER=insignia_custom
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=insignia_custom

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Existing Stitchs assets currently live in the former custom bucket/domain.
# Keep these values unless you migrate/copy the bucket contents and update URLs.
R2_BUCKET_NAME=insignia-custom-assets
R2_PUBLIC_URL=https://assets-custom.optidigi.nl

CRON_SECRET=
DESIGN_FEES_ENABLED=true
SENTRY_DSN=
RESEND_API_KEY=
APP_VERSION=latest

# SHOP_CUSTOM_DOMAIN=
