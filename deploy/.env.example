# ── Insignia Production Environment ─────────────────────────────────────────
# Copy to /srv/saas/infra/stacks/insignia/.env and fill in all values.
# Never commit the real .env to git.
# Set permissions: chmod 600 .env

# ── Shopify ───────────────────────────────────────────────────────────────────
# Get these from Shopify Partner Dashboard → Apps → <your app> → API credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Must match the [access_scopes] in shopify.app.insignia.toml exactly.
SCOPES=write_products,read_products,read_orders,write_orders,write_app_proxy,write_publications,write_inventory,read_themes
SHOPIFY_APP_URL=https://insignia.optidigi.nl

# ── Database (app connection string) ─────────────────────────────────────────
# "db" is the Docker service name — reachable by the app on the internal network
DATABASE_URL=postgresql://insignia:CHANGE_ME@db:5432/insignia

# ── Database (PostgreSQL container init) ─────────────────────────────────────
# POSTGRES_PASSWORD must match the password in DATABASE_URL above
POSTGRES_USER=insignia
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=insignia

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
# Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=insignia-assets
# Stable public URL for placeholder logos (Cloudflare R2 custom domain or r2.dev URL)
R2_PUBLIC_URL=https://assets.optidigi.nl

# ── Cron Authentication ───────────────────────────────────────────────────────
# Required — all /api/admin/cron/* endpoints verify this secret.
# Generate with: openssl rand -hex 32
# Use in cron: curl -H "Authorization: Bearer $CRON_SECRET" ...
CRON_SECRET=

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Obtain from sentry.io → Project → Settings → Client Keys (DSN).
# Leave empty to disable Sentry (the app starts normally without it).
SENTRY_DSN=

# ── Merchant Email Notifications (Resend) ─────────────────────────────────────
# Obtain from resend.com → API Keys.
# Leave empty to disable email notifications (orders still process normally).
RESEND_API_KEY=

# ── Deployment ────────────────────────────────────────────────────────────────
# Set to a specific version tag (e.g. v1.0.0) or leave as "latest"
APP_VERSION=latest

# ── Optional ──────────────────────────────────────────────────────────────────
# SHOP_CUSTOM_DOMAIN=
