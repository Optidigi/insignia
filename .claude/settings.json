{
  "hooks": [
    {
      "trigger": "PreToolUse",
      "commandMatch": "Edit|Write|MultiEdit",
      "command": "./.claude/hooks/pre-write-risky-paths.sh"
    },
    {
      "trigger": "PostToolUse",
      "commandMatch": "Edit|Write|MultiEdit",
      "command": "./.claude/hooks/post-edit-lint.sh"
    },
    {
      "trigger": "PostToolUse",
      "commandMatch": "Test|Bash",
      "command": "./.claude/hooks/post-test-summary.sh"
    },
    {
      "trigger": "PreToolUse",
      "commandMatch": "Commit|Merge",
      "command": "./.claude/hooks/pre-merge-verify.sh"
    },
    {
      "trigger": "PostToolUse",
      "commandMatch": "Task",
      "command": "./.claude/hooks/post-agent-log.sh"
    },
    {
      "trigger": "PostToolUse",
      "commandMatch": ".*",
      "command": "./.claude/hooks/post-tool-action-log.sh"
    }
  ],
  "agentSettings": {
    "maxTaskDepth": 4,
    "defaultModel": "sonnet"
  }
}
