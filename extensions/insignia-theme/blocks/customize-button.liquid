{% comment %}
  Insignia Customize — app block for product page.
  Add this block to the main product section in the theme editor.
  Opens the customization modal at /apps/insignia/modal (App Proxy).

  The button inherits the theme's button styling via the standard Shopify
  button class, so it matches Add to Cart and other theme buttons.
{% endcomment %}

{% assign insignia_enabled = false %}
{% if product.metafields.insignia.enabled == "true" %}
  {% assign insignia_enabled = true %}
{% endif %}
{% if request.design_mode %}
  {% assign insignia_enabled = true %}
{% endif %}
{% if product and product.selected_or_first_available_variant and insignia_enabled %}
  {% comment %}Extract numeric IDs — Liquid product.id returns the full GID (gid://shopify/Product/...)
    which Shopify's App Proxy cannot route. We need only the numeric tail.{% endcomment %}
  {% assign product_numeric_id = product.id | split: '/' | last %}
  {% assign variant_numeric_id = product.selected_or_first_available_variant.id | split: '/' | last %}
  {% assign encoded_return = product.url | url_encode %}
  {% assign modal_url = '/apps/insignia/modal?p=' | append: product_numeric_id | append: '&v=' | append: variant_numeric_id | append: '&returnUrl=' | append: encoded_return %}

  {% case block.settings.button_size %}
    {% when 's' %}
      {% assign btn_font = 13 %}
      {% assign btn_py = 10 %}
      {% assign btn_px = 20 %}
    {% when 'l' %}
      {% assign btn_font = 17 %}
      {% assign btn_py = 16 %}
      {% assign btn_px = 36 %}
    {% else %}
      {% assign btn_font = block.settings.font_size %}
      {% assign btn_py = block.settings.padding_y %}
      {% assign btn_px = block.settings.padding_x %}
  {% endcase %}

  <div class="insignia-customize-block" {{ block.shopify_attributes }}>
    <a
      href="{% if request.design_mode %}#{% else %}{{ modal_url }}{% endif %}"
      class="insignia-customize-button {% if block.settings.use_theme_style %}button button--primary btn btn--primary btn--solid button-primary{% endif %} {{ block.settings.custom_class }}"
      {% if request.design_mode %}onclick="event.preventDefault();"{% endif %}
      {% if block.settings.use_theme_style %}data-insignia-theme-style{% endif %}
      data-insignia-modal
      data-product-id="{{ product_numeric_id }}"
      data-variant-id="{{ variant_numeric_id }}"
      {% if block.settings.custom_id != blank %}id="{{ block.settings.custom_id }}"{% endif %}
    >
      {{ block.settings.button_label }}
    </a>
  </div>

  <style>
    .insignia-customize-block {
      margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
    }

    /* Accessibility: visible focus indicator in both modes */
    .insignia-customize-button:focus-visible {
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }

    {% if block.settings.use_theme_style %}
      /* Structural/layout only — the theme class cascade (button, button--primary,
         btn, btn--primary, btn--solid, button-primary) handles all visual styling.
         We deliberately set NO visual properties here so we don't fight the theme. */
      .insignia-customize-button {
        text-decoration: none;
        width: {% if block.settings.full_width %}100%{% else %}auto{% endif %};
        box-sizing: border-box;
        min-height: 44px;
        min-width: 44px;
      }

      /* Zero-specificity CSS-variable fallback for Dawn-lineage themes that expose
         CSS custom properties but may not match any of the class names above.
         :where() reduces specificity to (0,0,0) so ANY single theme class rule wins. */
      :where(.insignia-customize-button) {
        display: inline-block;
        text-align: center;
        cursor: pointer;
        padding: 15px 30px;
        background: rgb(var(--color-button, 18 18 18) / var(--alpha-button-background, 1));
        color: rgb(var(--color-button-text, 255 255 255));
        border-radius: var(--buttons-radius, 4px);
        border: var(--buttons-border-width, 1px) solid rgb(var(--color-button, 18 18 18) / var(--alpha-button-border, 1));
        font-family: var(--font-body-family, inherit);
        font-size: 14px;
      }
    {% else %}
      /* Custom Insignia styling */
      .insignia-customize-button {
        display: inline-block;
        padding: {{ btn_py }}px {{ btn_px }}px;
        background: {{ block.settings.background_color }};
        color: {{ block.settings.text_color }};
        text-decoration: none;
        border-radius: {{ block.settings.border_radius }}px;
        font-weight: 500;
        font-size: {{ btn_font }}px;
        font-family: inherit;
        letter-spacing: 0.05em;
        border: none;
        cursor: pointer;
        transition: opacity 150ms ease;
        width: {% if block.settings.full_width %}100%{% else %}auto{% endif %};
        min-height: 44px;
        min-width: 44px;
        text-align: center;
        {% if block.settings.uppercase %}text-transform: uppercase;{% endif %}
      }
      .insignia-customize-button:hover {
        opacity: 0.85;
        color: {{ block.settings.text_color }};
      }
    {% endif %}
  </style>
{% endif %}

{% schema %}
{
  "name": "Insignia Customize",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Customize"
    },
    {
      "type": "checkbox",
      "id": "use_theme_style",
      "label": "Use theme button style",
      "default": true,
      "info": "When enabled, the button inherits your theme's button styling to match Add to Cart and other buttons."
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "options": [
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" }
      ],
      "default": "m"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 8
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Bottom margin",
      "default": 8
    },
    {
      "type": "header",
      "content": "Custom style"
    },
    {
      "type": "paragraph",
      "content": "These settings only apply when 'Use theme button style' is disabled."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase text",
      "default": false
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_x",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 28
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom HTML ID",
      "info": "Optional ID attribute for CSS targeting"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class",
      "info": "Optional additional CSS class"
    }
  ]
}
{% endschema %}
